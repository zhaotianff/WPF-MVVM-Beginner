<Window x:Class="_16_Prism_DialogService.Views.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_16_Prism_DialogService"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Content="显示对话框" HorizontalAlignment="Center" VerticalAlignment="Center" Width="88" Height="28" Command="{Binding ShowDialogCommand}"></Button>
        <Label Content="{Binding DialogResultContent}" VerticalAlignment="Center" Margin="0,120,0,0" HorizontalAlignment="Center" FontSize="18"></Label>
    </Grid>
</Window>
