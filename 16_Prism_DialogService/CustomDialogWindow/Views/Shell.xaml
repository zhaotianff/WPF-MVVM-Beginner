<Window x:Class="CustomDialogWindow.Views.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:CustomDialogWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <Button Content="显示对话框" HorizontalAlignment="Center" VerticalAlignment="Center" Width="88" Height="28" Command="{Binding ShowDialogCommand}"></Button>
        <Label Content="{Binding DialogResultContent}" VerticalAlignment="Center" Margin="0,120,0,0" HorizontalAlignment="Center" FontSize="18"></Label>
    </Grid>
</Window>
